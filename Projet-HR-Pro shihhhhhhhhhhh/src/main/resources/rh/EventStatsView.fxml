<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="0"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.RhPro.controllers.rh.EventStatsController"
      style="-fx-background-color:#f3f0fa;">

    <HBox alignment="CENTER_LEFT" spacing="16"
          style="-fx-background-color:#6d2269;
                 -fx-padding:20 30;
                 -fx-effect:dropshadow(gaussian,rgba(109,34,105,0.45),18,0,0,6);">
        <Label text="📊" style="-fx-font-size:26px;"/>
        <VBox spacing="2">
            <Label text="Statistiques des Evenements"
                   style="-fx-font-size:22px; -fx-font-weight:900; -fx-text-fill:white;"/>
            <Label text="Analyse complete des participations - HR PRO"
                   style="-fx-font-size:12px; -fx-text-fill:rgba(255,255,255,0.72);"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Actualiser" onAction="#refresh"
                style="-fx-background-color:rgba(255,255,255,0.18); -fx-text-fill:white;
                       -fx-font-weight:800; -fx-font-size:13px;
                       -fx-background-radius:30; -fx-border-color:rgba(255,255,255,0.35);
                       -fx-border-width:1.5; -fx-border-radius:30;
                       -fx-padding:10 22; -fx-cursor:hand;"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color:transparent; -fx-background:#f3f0fa;"
                vbarPolicy="AS_NEEDED" hbarPolicy="NEVER">
        <VBox spacing="20" style="-fx-padding:24 28 28 28; -fx-background-color:#f3f0fa;">

            <HBox spacing="16">

                <VBox spacing="8" HBox.hgrow="ALWAYS"
                      style="-fx-background-color:white; -fx-background-radius:22;
                             -fx-border-color:#e0d9f7; -fx-border-width:1.5; -fx-border-radius:22;
                             -fx-padding:22;
                             -fx-effect:dropshadow(gaussian,rgba(109,34,105,0.12),16,0,0,4);">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="EVENEMENTS"
                               style="-fx-font-size:11px; -fx-font-weight:800; -fx-text-fill:#9c5c9a;"/>
                    </HBox>
                    <Label fx:id="totalEventsLabel" text="0"
                           style="-fx-font-size:44px; -fx-font-weight:900; -fx-text-fill:#3d1a3b;"/>
                    <Label text="Total crees"
                           style="-fx-font-size:12px; -fx-text-fill:#9c5c9a;"/>
                </VBox>

                <VBox spacing="8" HBox.hgrow="ALWAYS"
                      style="-fx-background-color:white; -fx-background-radius:22;
                             -fx-border-color:#bfdbfe; -fx-border-width:1.5; -fx-border-radius:22;
                             -fx-padding:22;
                             -fx-effect:dropshadow(gaussian,rgba(37,99,235,0.10),16,0,0,4);">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="PARTICIPATIONS"
                               style="-fx-font-size:11px; -fx-font-weight:800; -fx-text-fill:#1d4ed8;"/>
                    </HBox>
                    <Label fx:id="totalParticipationsLabel" text="0"
                           style="-fx-font-size:44px; -fx-font-weight:900; -fx-text-fill:#1d4ed8;"/>
                    <Label text="Total inscriptions"
                           style="-fx-font-size:12px; -fx-text-fill:#60a5fa;"/>
                </VBox>

                <VBox spacing="8" HBox.hgrow="ALWAYS"
                      style="-fx-background-color:white; -fx-background-radius:22;
                             -fx-border-color:#a7f3d0; -fx-border-width:1.5; -fx-border-radius:22;
                             -fx-padding:22;
                             -fx-effect:dropshadow(gaussian,rgba(5,150,105,0.10),16,0,0,4);">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="ACCEPTEES"
                               style="-fx-font-size:11px; -fx-font-weight:800; -fx-text-fill:#059669;"/>
                    </HBox>
                    <Label fx:id="totalAcceptedLabel" text="0"
                           style="-fx-font-size:44px; -fx-font-weight:900; -fx-text-fill:#059669;"/>
                    <Label text="Validees"
                           style="-fx-font-size:12px; -fx-text-fill:#34d399;"/>
                </VBox>

                <VBox spacing="8" HBox.hgrow="ALWAYS"
                      style="-fx-background-color:white; -fx-background-radius:22;
                             -fx-border-color:#fde68a; -fx-border-width:1.5; -fx-border-radius:22;
                             -fx-padding:22;
                             -fx-effect:dropshadow(gaussian,rgba(245,158,11,0.10),16,0,0,4);">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="EN ATTENTE"
                               style="-fx-font-size:11px; -fx-font-weight:800; -fx-text-fill:#d97706;"/>
                    </HBox>
                    <Label fx:id="totalPendingLabel" text="0"
                           style="-fx-font-size:44px; -fx-font-weight:900; -fx-text-fill:#d97706;"/>
                    <Label text="En validation"
                           style="-fx-font-size:12px; -fx-text-fill:#fbbf24;"/>
                </VBox>

            </HBox>

            <VBox spacing="16"
                  style="-fx-background-color:white; -fx-background-radius:24;
                         -fx-border-color:#e0d9f7; -fx-border-width:1.5; -fx-border-radius:24;
                         -fx-padding:24;
                         -fx-effect:dropshadow(gaussian,rgba(109,34,105,0.08),16,0,0,4);">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="📈"
                           style="-fx-font-size:15px; -fx-text-fill:white;
                                  -fx-background-color:#6d2269; -fx-background-radius:50;
                                  -fx-min-width:32; -fx-min-height:32; -fx-alignment:center;"/>
                    <VBox spacing="2">
                        <Label text="Participations par evenement"
                               style="-fx-font-size:16px; -fx-font-weight:900; -fx-text-fill:#3d1a3b;"/>
                        <Label text="Classement du plus participe au moins participe"
                               style="-fx-font-size:11px; -fx-text-fill:#9c5c9a;"/>
                    </VBox>
                </HBox>
                <Separator style="-fx-background-color:#f0ebf9;"/>
                <VBox fx:id="chartContainer" spacing="12" style="-fx-padding:4 0 0 0;"/>
            </VBox>

            <VBox spacing="16"
                  style="-fx-background-color:white; -fx-background-radius:24;
                         -fx-border-color:#e0d9f7; -fx-border-width:1.5; -fx-border-radius:24;
                         -fx-padding:24;
                         -fx-effect:dropshadow(gaussian,rgba(109,34,105,0.08),16,0,0,4);">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="🏆"
                           style="-fx-font-size:15px; -fx-text-fill:white;
                                  -fx-background-color:#6d2269; -fx-background-radius:50;
                                  -fx-min-width:32; -fx-min-height:32; -fx-alignment:center;"/>
                    <VBox spacing="2">
                        <Label text="Top 5 - Detail des participations"
                               style="-fx-font-size:16px; -fx-font-weight:900; -fx-text-fill:#3d1a3b;"/>
                        <Label text="Evenements avec le plus d inscriptions"
                               style="-fx-font-size:11px; -fx-text-fill:#9c5c9a;"/>
                    </VBox>
                </HBox>
                <Separator style="-fx-background-color:#f0ebf9;"/>
                <VBox fx:id="topListContainer" spacing="12"/>
            </VBox>

        </VBox>
    </ScrollPane>
</VBox>
