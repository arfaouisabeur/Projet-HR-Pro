<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="0"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.RhPro.controllers.rh.EventsManageController"
      style="-fx-background-color:#f3f0fa;">

    <!-- ══════════════════════════════════════════ -->
    <!-- HEADER                                     -->
    <!-- ══════════════════════════════════════════ -->
    <HBox alignment="CENTER_LEFT" spacing="16"
          style="-fx-background-color:#6d2269;
                 -fx-padding:20 30;
                 -fx-effect:dropshadow(gaussian,rgba(109,34,105,0.45),18,0,0,6);">

        <Label text="🎉" style="-fx-font-size:26px;"/>

        <VBox spacing="2">
            <Label text="Gestion des Événements"
                   style="-fx-font-size:22px; -fx-font-weight:900; -fx-text-fill:white;"/>
            <Label text="Créez, modifiez et gérez vos événements"
                   style="-fx-font-size:12px; -fx-text-fill:rgba(255,255,255,0.72);"/>
        </VBox>

        <Region HBox.hgrow="ALWAYS"/>

        <Label fx:id="msgLabel"
               style="-fx-font-size:13px; -fx-font-weight:800;
                      -fx-text-fill:white; -fx-background-color:rgba(255,255,255,0.18);
                      -fx-background-radius:20; -fx-padding:6 18;"/>
    </HBox>

    <!-- ══════════════════════════════════════════ -->
    <!-- NAVIGATION BUTTONS — CENTERED              -->
    <!-- ══════════════════════════════════════════ -->
    <HBox alignment="CENTER" spacing="14"
          style="-fx-background-color:white;
                 -fx-padding:16 30;
                 -fx-effect:dropshadow(gaussian,rgba(109,34,105,0.07),10,0,0,3);
                 -fx-border-color:#f0ebf9; -fx-border-width:0 0 1.5 0;">

        <Button text="🔄  Rafraîchir" onAction="#refresh"
                style="-fx-background-color:#f0ebf9; -fx-text-fill:#6d2269;
                       -fx-font-weight:800; -fx-font-size:12px;
                       -fx-background-radius:30; -fx-border-radius:30;
                       -fx-border-color:#d8b4d6; -fx-border-width:1.5;
                       -fx-padding:10 20; -fx-cursor:hand;"/>

        <Button text="📋  Activités" onAction="#openActivites"
                style="-fx-background-color:#6d2269; -fx-text-fill:white;
                       -fx-font-weight:800; -fx-font-size:12px;
                       -fx-background-radius:30;
                       -fx-padding:10 20; -fx-cursor:hand;
                       -fx-effect:dropshadow(gaussian,rgba(109,34,105,0.35),10,0,0,3);"/>

        <Button text="👥  Participations" onAction="#openParticipations"
                style="-fx-background-color:#059669; -fx-text-fill:white;
                       -fx-font-weight:800; -fx-font-size:12px;
                       -fx-background-radius:30;
                       -fx-padding:10 20; -fx-cursor:hand;
                       -fx-effect:dropshadow(gaussian,rgba(5,150,105,0.35),10,0,0,3);"/>

        <Button text="📊  Statistiques" onAction="#openStatistiques"
                style="-fx-background-color:#7c3aed; -fx-text-fill:white;
                       -fx-font-weight:800; -fx-font-size:12px;
                       -fx-background-radius:30;
                       -fx-padding:10 20; -fx-cursor:hand;
                       -fx-effect:dropshadow(gaussian,rgba(124,58,237,0.35),10,0,0,3);"/>

        <Button text="📅  Calendrier" onAction="#goCalendrier"
                style="-fx-background-color:#0891b2; -fx-text-fill:white;
                       -fx-font-weight:800; -fx-font-size:12px;
                       -fx-background-radius:30;
                       -fx-padding:10 20; -fx-cursor:hand;
                       -fx-effect:dropshadow(gaussian,rgba(8,145,178,0.35),10,0,0,3);"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color:transparent; -fx-background:#f3f0fa;">
        <VBox spacing="22" style="-fx-padding:26 30;">

            <!-- ══════════════════════════════════════════ -->
            <!-- TABLE CARD                                 -->
            <!-- ══════════════════════════════════════════ -->
            <VBox spacing="16"
                  style="-fx-background-color:white;
                         -fx-background-radius:24;
                         -fx-effect:dropshadow(gaussian,rgba(109,34,105,0.10),22,0,0,6);
                         -fx-padding:28;">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="📋"
                           style="-fx-font-size:15px; -fx-text-fill:white;
                                  -fx-background-color:#6d2269; -fx-background-radius:50;
                                  -fx-min-width:32; -fx-min-height:32; -fx-alignment:center;"/>
                    <Label text="Liste des événements"
                           style="-fx-font-size:17px; -fx-font-weight:900; -fx-text-fill:#3d1a3b;"/>
                </HBox>

                <Separator style="-fx-background-color:#f0ebf9;"/>

                <TableView fx:id="table" prefHeight="280" VBox.vgrow="ALWAYS"
                           style="-fx-background-color:#faf8ff;
                                  -fx-background-radius:14; -fx-border-radius:14;
                                  -fx-border-color:#e0d9f7; -fx-border-width:1.5;">
                    <columns>
                        <TableColumn fx:id="colId"     text="ID"          prefWidth="50"/>
                        <TableColumn fx:id="colTitre"  text="Titre"       prefWidth="150"/>
                        <TableColumn fx:id="colDebut"  text="Début"       prefWidth="130"/>
                        <TableColumn fx:id="colFin"    text="Fin"         prefWidth="130"/>
                        <TableColumn fx:id="colLieu"   text="Lieu"        prefWidth="110"/>
                        <TableColumn fx:id="colImage"  text="Image"       prefWidth="100"/>
                        <TableColumn fx:id="colDesc"   text="Description" prefWidth="220"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- ══════════════════════════════════════════ -->
            <!-- FORM + IMAGE — SIDE BY SIDE               -->
            <!-- ══════════════════════════════════════════ -->
            <HBox spacing="20" alignment="TOP_LEFT">

                <!-- LEFT: Form Fields -->
                <VBox spacing="20" HBox.hgrow="ALWAYS"
                      style="-fx-background-color:white;
                             -fx-background-radius:24;
                             -fx-effect:dropshadow(gaussian,rgba(109,34,105,0.10),22,0,0,6);
                             -fx-padding:28;">

                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="✎"
                               style="-fx-font-size:15px; -fx-text-fill:white;
                                      -fx-background-color:#6d2269; -fx-background-radius:50;
                                      -fx-min-width:32; -fx-min-height:32; -fx-alignment:center;"/>
                        <Label text="Formulaire événement"
                               style="-fx-font-size:17px; -fx-font-weight:900; -fx-text-fill:#3d1a3b;"/>
                    </HBox>

                    <Separator style="-fx-background-color:#f0ebf9;"/>

                    <!-- Titre + Lieu -->
                    <HBox spacing="18" alignment="CENTER_LEFT">
                        <VBox spacing="7" HBox.hgrow="ALWAYS">
                            <Label text="Titre *"
                                   style="-fx-font-weight:800; -fx-font-size:12px; -fx-text-fill:#6d2269;"/>
                            <TextField fx:id="titreField" promptText="Titre de l'événement"
                                       style="-fx-background-radius:14; -fx-border-radius:14;
                                              -fx-border-color:#e0d9f7; -fx-border-width:1.5;
                                              -fx-font-size:13px; -fx-padding:9 12;"/>
                            <Label fx:id="titreError" text="" managed="false"
                                   style="-fx-text-fill:#dc2626; -fx-font-size:11px; -fx-font-weight:700;"/>
                        </VBox>

                        <VBox spacing="7" HBox.hgrow="ALWAYS">
                            <Label text="Lieu *"
                                   style="-fx-font-weight:800; -fx-font-size:12px; -fx-text-fill:#6d2269;"/>
                            <HBox spacing="8">
                                <TextField fx:id="lieuField" promptText="Lieu de l'événement"
                                           HBox.hgrow="ALWAYS"
                                           style="-fx-background-radius:14; -fx-border-radius:14;
                                                  -fx-border-color:#e0d9f7; -fx-border-width:1.5;
                                                  -fx-font-size:13px; -fx-padding:9 12;"/>
                                <Button fx:id="pickLocationButton" text="🗺️ Carte"
                                        style="-fx-background-color:#6d2269; -fx-text-fill:white;
                                               -fx-font-weight:700; -fx-background-radius:14;
                                               -fx-padding:9 14; -fx-cursor:hand; -fx-font-size:12px;
                                               -fx-effect:dropshadow(gaussian,rgba(109,34,105,0.3),8,0,0,2);"/>
                            </HBox>
                            <Label fx:id="locationCoordinatesLabel" text=""
                                   style="-fx-text-fill:#059669; -fx-font-size:11px;"/>
                            <Label fx:id="lieuError" text="" managed="false"
                                   style="-fx-text-fill:#dc2626; -fx-font-size:11px; -fx-font-weight:700;"/>
                        </VBox>
                    </HBox>

                    <!-- Dates -->
                    <HBox spacing="18" alignment="CENTER_LEFT">
                        <VBox spacing="7" HBox.hgrow="ALWAYS">
                            <Label text="Date début *"
                                   style="-fx-font-weight:800; -fx-font-size:12px; -fx-text-fill:#6d2269;"/>
                            <HBox spacing="8">
                                <DatePicker fx:id="dateDebutPicker" HBox.hgrow="ALWAYS"
                                            style="-fx-background-radius:14; -fx-border-radius:14;
                                                   -fx-border-color:#e0d9f7; -fx-border-width:1.5; -fx-font-size:13px;"/>
                                <TextField fx:id="heureDebutField" promptText="HH:MM" prefWidth="82"
                                           style="-fx-background-radius:14; -fx-border-radius:14;
                                                  -fx-border-color:#e0d9f7; -fx-border-width:1.5;
                                                  -fx-font-size:13px; -fx-padding:9 10;"/>
                            </HBox>
                            <HBox spacing="8">
                                <Label fx:id="dateDebutError" text="" managed="false" HBox.hgrow="ALWAYS"
                                       style="-fx-text-fill:#dc2626; -fx-font-size:11px; -fx-font-weight:700;"/>
                                <Label fx:id="heureDebutError" text="" managed="false" prefWidth="82"
                                       style="-fx-text-fill:#dc2626; -fx-font-size:11px; -fx-font-weight:700;"/>
                            </HBox>
                        </VBox>

                        <VBox spacing="7" HBox.hgrow="ALWAYS">
                            <Label text="Date fin *"
                                   style="-fx-font-weight:800; -fx-font-size:12px; -fx-text-fill:#6d2269;"/>
                            <HBox spacing="8">
                                <DatePicker fx:id="dateFinPicker" HBox.hgrow="ALWAYS"
                                            style="-fx-background-radius:14; -fx-border-radius:14;
                                                   -fx-border-color:#e0d9f7; -fx-border-width:1.5; -fx-font-size:13px;"/>
                                <TextField fx:id="heureFinField" promptText="HH:MM" prefWidth="82"
                                           style="-fx-background-radius:14; -fx-border-radius:14;
                                                  -fx-border-color:#e0d9f7; -fx-border-width:1.5;
                                                  -fx-font-size:13px; -fx-padding:9 10;"/>
                            </HBox>
                            <HBox spacing="8">
                                <Label fx:id="dateFinError" text="" managed="false" HBox.hgrow="ALWAYS"
                                       style="-fx-text-fill:#dc2626; -fx-font-size:11px; -fx-font-weight:700;"/>
                                <Label fx:id="heureFinError" text="" managed="false" prefWidth="82"
                                       style="-fx-text-fill:#dc2626; -fx-font-size:11px; -fx-font-weight:700;"/>
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- Description -->
                    <VBox spacing="7">
                        <Label text="Description *"
                               style="-fx-font-weight:800; -fx-font-size:12px; -fx-text-fill:#6d2269;"/>
                        <TextArea fx:id="descArea" promptText="Décrivez l'événement…"
                                  wrapText="true" prefRowCount="3"
                                  style="-fx-background-radius:14; -fx-border-radius:14;
                                         -fx-border-color:#e0d9f7; -fx-border-width:1.5;
                                         -fx-font-size:13px; -fx-padding:10;"/>
                        <Label fx:id="descError" text="" managed="false"
                               style="-fx-text-fill:#dc2626; -fx-font-size:11px; -fx-font-weight:700;"/>
                    </VBox>

                    <!-- Action buttons — CENTERED -->
                    <HBox spacing="12" alignment="CENTER">
                        <Button text="🧹 Effacer" onAction="#clearForm"
                                style="-fx-background-color:#f0ebf9; -fx-text-fill:#6d2269;
                                       -fx-font-weight:800; -fx-background-radius:30; -fx-border-radius:30;
                                       -fx-border-color:#d8b4d6; -fx-border-width:1.5;
                                       -fx-padding:12 24; -fx-cursor:hand; -fx-font-size:13px;"/>
                        <Button text="➕ Ajouter" onAction="#add"
                                style="-fx-background-color:#059669; -fx-text-fill:white;
                                       -fx-font-weight:900; -fx-background-radius:30;
                                       -fx-padding:12 24; -fx-cursor:hand; -fx-font-size:13px;
                                       -fx-effect:dropshadow(gaussian,rgba(5,150,105,0.40),12,0,0,3);"/>
                        <Button text="✏️ Mettre à jour" onAction="#update"
                                style="-fx-background-color:#6d2269; -fx-text-fill:white;
                                       -fx-font-weight:900; -fx-background-radius:30;
                                       -fx-padding:12 24; -fx-cursor:hand; -fx-font-size:13px;
                                       -fx-effect:dropshadow(gaussian,rgba(109,34,105,0.40),12,0,0,3);"/>
                        <Button text="🗑️ Supprimer" onAction="#delete"
                                style="-fx-background-color:#dc2626; -fx-text-fill:white;
                                       -fx-font-weight:900; -fx-background-radius:30;
                                       -fx-padding:12 24; -fx-cursor:hand; -fx-font-size:13px;
                                       -fx-effect:dropshadow(gaussian,rgba(220,38,38,0.40),12,0,0,3);"/>
                    </HBox>

                </VBox>

                <!-- RIGHT: Image Uploader -->
                <VBox spacing="14" prefWidth="270"
                      style="-fx-background-color:white;
                             -fx-background-radius:24;
                             -fx-effect:dropshadow(gaussian,rgba(109,34,105,0.10),22,0,0,6);
                             -fx-padding:28;">

                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="📷"
                               style="-fx-font-size:15px; -fx-text-fill:white;
                                      -fx-background-color:#6d2269; -fx-background-radius:50;
                                      -fx-min-width:32; -fx-min-height:32; -fx-alignment:center;"/>
                        <Label text="Image de l'événement"
                               style="-fx-font-size:15px; -fx-font-weight:900; -fx-text-fill:#3d1a3b;"/>
                    </HBox>

                    <Separator style="-fx-background-color:#f0ebf9;"/>

                    <VBox fx:id="imageUploaderContainer" spacing="10" VBox.vgrow="ALWAYS"
                          style="-fx-background-color:#f8f5ff;
                                 -fx-background-radius:16; -fx-border-color:#e0d9f7;
                                 -fx-border-radius:16; -fx-border-width:1.5;
                                 -fx-padding:16; -fx-alignment:center; -fx-min-height:130;"/>

                    <VBox spacing="7">
                        <Label text="Ou entrez une URL :"
                               style="-fx-font-weight:800; -fx-font-size:12px; -fx-text-fill:#6d2269;"/>
                        <TextField fx:id="imageUrlField" promptText="https://…"
                                   style="-fx-background-radius:14; -fx-border-radius:14;
                                          -fx-border-color:#e0d9f7; -fx-border-width:1.5;
                                          -fx-font-size:13px; -fx-padding:9 12;"/>
                        <Label fx:id="imageUrlError" text="" managed="false"
                               style="-fx-text-fill:#dc2626; -fx-font-size:11px; -fx-font-weight:700;"/>
                    </VBox>

                    <Region VBox.vgrow="ALWAYS"/>

                    <Label text="ⓘ Formats : JPG, PNG, GIF"
                           style="-fx-text-fill:#9c5c9a; -fx-font-size:11px;
                                  -fx-background-color:#f0ebf9; -fx-background-radius:10; -fx-padding:6 12;"/>
                </VBox>
            </HBox>

            <!-- ══════════════════════════════════════════ -->
            <!-- FOOTER INFO BAR                           -->
            <!-- ══════════════════════════════════════════ -->
            <HBox spacing="20" alignment="CENTER"
                  style="-fx-background-color:white;
                         -fx-background-radius:18;
                         -fx-effect:dropshadow(gaussian,rgba(109,34,105,0.07),12,0,0,3);
                         -fx-padding:14 22;">
                <Label text="ⓘ * Champs obligatoires"
                       style="-fx-text-fill:#9c5c9a; -fx-font-size:12px; -fx-font-weight:700;"/>
                <Label text="│" style="-fx-text-fill:#e0d9f7; -fx-font-size:16px;"/>
                <Label text="📷 Cliquez sur l'image pour télécharger"
                       style="-fx-text-fill:#9c5c9a; -fx-font-size:12px;"/>
                <Label text="│" style="-fx-text-fill:#e0d9f7; -fx-font-size:16px;"/>
                <Label text="🗺️ Carte pour choisir un lieu"
                       style="-fx-text-fill:#9c5c9a; -fx-font-size:12px;"/>
            </HBox>

        </VBox>
    </ScrollPane>

</VBox>
