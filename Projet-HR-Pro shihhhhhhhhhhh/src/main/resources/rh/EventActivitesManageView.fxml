<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="0"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.RhPro.controllers.rh.EventActivitesManageController"
      style="-fx-background-color:#f3f0fa;">

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="16"
          style="-fx-background-color:#6d2269;
                 -fx-padding:20 30;
                 -fx-effect:dropshadow(gaussian,rgba(109,34,105,0.45),18,0,0,6);">
        <Label text="📋" style="-fx-font-size:26px;"/>
        <VBox spacing="2">
            <Label fx:id="titleLabel" text="Activités de l'événement"
                   style="-fx-font-size:22px; -fx-font-weight:900; -fx-text-fill:white;"/>
            <Label text="Gérez les activités associées à cet événement"
                   style="-fx-font-size:12px; -fx-text-fill:rgba(255,255,255,0.72);"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="msgLabel"
               style="-fx-font-size:13px; -fx-font-weight:800; -fx-text-fill:white;
                      -fx-background-color:rgba(255,255,255,0.18);
                      -fx-background-radius:20; -fx-padding:6 18;"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color:transparent; -fx-background:#f3f0fa;">
        <VBox spacing="22" style="-fx-padding:26 30;">

            <!-- TABLE CARD -->
            <VBox spacing="16"
                  style="-fx-background-color:white; -fx-background-radius:24;
                         -fx-effect:dropshadow(gaussian,rgba(109,34,105,0.10),22,0,0,6);
                         -fx-padding:28;">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="📋"
                           style="-fx-font-size:15px; -fx-text-fill:white;
                                  -fx-background-color:#6d2269; -fx-background-radius:50;
                                  -fx-min-width:32; -fx-min-height:32; -fx-alignment:center;"/>
                    <Label text="Liste des activités"
                           style="-fx-font-size:17px; -fx-font-weight:900; -fx-text-fill:#3d1a3b;"/>
                </HBox>
                <Separator style="-fx-background-color:#f0ebf9;"/>
                <TableView fx:id="table" prefHeight="300" VBox.vgrow="ALWAYS"
                           style="-fx-background-color:#faf8ff; -fx-background-radius:14;
                                  -fx-border-radius:14; -fx-border-color:#e0d9f7; -fx-border-width:1.5;">
                    <columns>
                        <TableColumn fx:id="colId"    text="ID"          prefWidth="80"/>
                        <TableColumn fx:id="colTitre" text="Titre"       prefWidth="300"/>
                        <TableColumn fx:id="colDesc"  text="Description" prefWidth="500"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- FORM CARD -->
            <VBox spacing="20"
                  style="-fx-background-color:white; -fx-background-radius:24;
                         -fx-effect:dropshadow(gaussian,rgba(109,34,105,0.10),22,0,0,6);
                         -fx-padding:28;">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="✎"
                           style="-fx-font-size:15px; -fx-text-fill:white;
                                  -fx-background-color:#6d2269; -fx-background-radius:50;
                                  -fx-min-width:32; -fx-min-height:32; -fx-alignment:center;"/>
                    <Label text="Formulaire activité"
                           style="-fx-font-size:17px; -fx-font-weight:900; -fx-text-fill:#3d1a3b;"/>
                </HBox>
                <Separator style="-fx-background-color:#f0ebf9;"/>

                <!-- Titre -->
                <VBox spacing="7">
                    <Label text="Titre *"
                           style="-fx-font-weight:800; -fx-font-size:12px; -fx-text-fill:#6d2269;"/>
                    <TextField fx:id="titreField" promptText="Ex : Atelier pratique"
                               style="-fx-background-radius:14; -fx-border-radius:14;
                                      -fx-border-color:#e0d9f7; -fx-border-width:1.5;
                                      -fx-font-size:13px; -fx-padding:9 12;"/>
                    <Label fx:id="titreError" text="" managed="false"
                           style="-fx-text-fill:#dc2626; -fx-font-size:11px; -fx-font-weight:700;"/>
                </VBox>

                <!-- Description -->
                <VBox spacing="7">
                    <Label text="Description *"
                           style="-fx-font-weight:800; -fx-font-size:12px; -fx-text-fill:#6d2269;"/>
                    <TextArea fx:id="descArea" prefRowCount="3" wrapText="true"
                              promptText="Description détaillée de l'activité…"
                              style="-fx-background-radius:14; -fx-border-radius:14;
                                     -fx-border-color:#e0d9f7; -fx-border-width:1.5;
                                     -fx-font-size:13px; -fx-padding:10;"/>
                    <Label fx:id="descError" text="" managed="false"
                           style="-fx-text-fill:#dc2626; -fx-font-size:11px; -fx-font-weight:700;"/>
                </VBox>

                <!-- Buttons — CENTERED -->
                <HBox spacing="12" alignment="CENTER">
                    <Button text="🧹 Effacer" onAction="#clearForm"
                            style="-fx-background-color:#f0ebf9; -fx-text-fill:#6d2269;
                                   -fx-font-weight:800; -fx-background-radius:30; -fx-border-radius:30;
                                   -fx-border-color:#d8b4d6; -fx-border-width:1.5;
                                   -fx-padding:12 24; -fx-cursor:hand; -fx-font-size:13px;"/>
                    <Button text="🔄 Rafraîchir" onAction="#refresh"
                            style="-fx-background-color:#f0ebf9; -fx-text-fill:#6d2269;
                                   -fx-font-weight:800; -fx-background-radius:30; -fx-border-radius:30;
                                   -fx-border-color:#d8b4d6; -fx-border-width:1.5;
                                   -fx-padding:12 24; -fx-cursor:hand; -fx-font-size:13px;"/>
                    <Button text="➕ Ajouter" onAction="#add"
                            style="-fx-background-color:#059669; -fx-text-fill:white;
                                   -fx-font-weight:900; -fx-background-radius:30;
                                   -fx-padding:12 24; -fx-cursor:hand; -fx-font-size:13px;
                                   -fx-effect:dropshadow(gaussian,rgba(5,150,105,0.40),12,0,0,3);"/>
                    <Button text="✏️ Modifier" onAction="#update"
                            style="-fx-background-color:#6d2269; -fx-text-fill:white;
                                   -fx-font-weight:900; -fx-background-radius:30;
                                   -fx-padding:12 24; -fx-cursor:hand; -fx-font-size:13px;
                                   -fx-effect:dropshadow(gaussian,rgba(109,34,105,0.40),12,0,0,3);"/>
                    <Button text="🗑 Supprimer" onAction="#delete"
                            style="-fx-background-color:#dc2626; -fx-text-fill:white;
                                   -fx-font-weight:900; -fx-background-radius:30;
                                   -fx-padding:12 24; -fx-cursor:hand; -fx-font-size:13px;
                                   -fx-effect:dropshadow(gaussian,rgba(220,38,38,0.40),12,0,0,3);"/>
                </HBox>
            </VBox>

            <!-- FOOTER -->
            <HBox alignment="CENTER"
                  style="-fx-background-color:white; -fx-background-radius:18;
                         -fx-effect:dropshadow(gaussian,rgba(109,34,105,0.07),12,0,0,3);
                         -fx-padding:14 22;">
                <Label text="ⓘ * Champs obligatoires"
                       style="-fx-text-fill:#9c5c9a; -fx-font-size:12px; -fx-font-weight:700;"/>
            </HBox>

        </VBox>
    </ScrollPane>
</VBox>
