<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<HBox spacing="0"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.RhPro.controllers.rh.CalendrierController"
      style="-fx-background-color:#f3f0fa;">

    <!-- ═══ LEFT: Calendar ══════════════════════════════════════════════ -->
    <VBox spacing="0" HBox.hgrow="ALWAYS">

        <!-- HEADER — violet like MesConges -->
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color:#6d2269;
                     -fx-padding:20 30;
                     -fx-effect:dropshadow(gaussian,rgba(109,34,105,0.45),18,0,0,6);">
            <Label text="📅" style="-fx-font-size:26px;"/>
            <VBox spacing="2">
                <Label text="Calendrier des Jours Feries"
                       style="-fx-font-size:22px; -fx-font-weight:900; -fx-text-fill:white;"/>
                <Label text="Conges et jours feries - Tunisie"
                       style="-fx-font-size:12px; -fx-text-fill:rgba(255,255,255,0.72);"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusLabel" text=""
                   style="-fx-text-fill:white; -fx-font-size:12px; -fx-font-weight:700;
                          -fx-background-color:rgba(255,255,255,0.18);
                          -fx-background-radius:20; -fx-padding:5 14;"/>
        </HBox>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background-color:transparent; -fx-background:#f3f0fa;">
            <VBox spacing="18" style="-fx-padding:22 26;">

                <!-- Stats + action buttons row -->
                <HBox spacing="14" alignment="CENTER_LEFT">
                    <HBox spacing="8" alignment="CENTER_LEFT"
                          style="-fx-background-color:#fef2f2; -fx-background-radius:20;
                                 -fx-border-color:#fca5a5; -fx-border-width:1.5; -fx-border-radius:20;
                                 -fx-padding:10 18;">
                        <Label text="🎉" style="-fx-font-size:15px;"/>
                        <Label fx:id="holidayCountLabel" text="0 jour(s) ferie(s) ce mois"
                               style="-fx-font-size:12px; -fx-font-weight:700; -fx-text-fill:#dc2626;"/>
                    </HBox>
                    <HBox spacing="8" alignment="CENTER_LEFT"
                          style="-fx-background-color:#eff6ff; -fx-background-radius:20;
                                 -fx-border-color:#93c5fd; -fx-border-width:1.5; -fx-border-radius:20;
                                 -fx-padding:10 18;">
                        <Label text="🏖" style="-fx-font-size:15px;"/>
                        <Label fx:id="congeCountLabel" text="0 conge(s) ce mois"
                               style="-fx-font-size:12px; -fx-font-weight:700; -fx-text-fill:#1d4ed8;"/>
                    </HBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Aujourd'hui" onAction="#goToday"
                            style="-fx-background-color:#f0ebf9; -fx-text-fill:#6d2269;
                                   -fx-font-weight:800; -fx-font-size:12px;
                                   -fx-background-radius:20; -fx-border-radius:20;
                                   -fx-border-color:#d8b4d6; -fx-border-width:1.5;
                                   -fx-padding:9 18; -fx-cursor:hand;"/>
                    <Button text="🔄  Rafraichir" onAction="#refresh"
                            style="-fx-background-color:#6d2269; -fx-text-fill:white;
                                   -fx-font-weight:800; -fx-font-size:12px;
                                   -fx-background-radius:20; -fx-padding:9 18; -fx-cursor:hand;
                                   -fx-effect:dropshadow(gaussian,rgba(109,34,105,0.35),10,0,0,2);"/>
                </HBox>

                <!-- Month Navigation — white card -->
                <HBox alignment="CENTER" spacing="20"
                      style="-fx-background-color:white; -fx-background-radius:24;
                             -fx-border-color:#e0d9f7; -fx-border-width:1.5; -fx-border-radius:24;
                             -fx-padding:16 28;
                             -fx-effect:dropshadow(gaussian,rgba(109,34,105,0.08),16,0,0,4);">
                    <Button text="◀" onAction="#prevMonth"
                            style="-fx-background-color:#6d2269; -fx-text-fill:white;
                                   -fx-background-radius:20; -fx-padding:9 20; -fx-font-size:16px;
                                   -fx-font-weight:900; -fx-cursor:hand;
                                   -fx-effect:dropshadow(gaussian,rgba(109,34,105,0.40),10,0,0,2);"/>
                    <Label fx:id="monthYearLabel" text="Janvier 2026"
                           style="-fx-font-size:20px; -fx-font-weight:900; -fx-text-fill:#3d1a3b;"
                           minWidth="250" alignment="CENTER"/>
                    <Button text="▶" onAction="#nextMonth"
                            style="-fx-background-color:#6d2269; -fx-text-fill:white;
                                   -fx-background-radius:20; -fx-padding:9 20; -fx-font-size:16px;
                                   -fx-font-weight:900; -fx-cursor:hand;
                                   -fx-effect:dropshadow(gaussian,rgba(109,34,105,0.40),10,0,0,2);"/>
                </HBox>

                <!-- Calendar Grid — white card -->
                <VBox style="-fx-background-color:white; -fx-background-radius:24;
                             -fx-border-color:#e0d9f7; -fx-border-width:1.5; -fx-border-radius:24;
                             -fx-padding:20;
                             -fx-effect:dropshadow(gaussian,rgba(109,34,105,0.08),18,0,0,5);"
                      VBox.vgrow="ALWAYS">
                    <GridPane fx:id="calendarGrid" hgap="8" vgap="8" VBox.vgrow="ALWAYS"/>
                </VBox>

                <!-- Legend — white card -->
                <HBox spacing="20" alignment="CENTER_LEFT"
                      style="-fx-background-color:white; -fx-background-radius:18;
                             -fx-border-color:#e0d9f7; -fx-border-width:1.5; -fx-border-radius:18;
                             -fx-padding:12 22;
                             -fx-effect:dropshadow(gaussian,rgba(109,34,105,0.06),10,0,0,2);">
                    <Label text="Legende :"
                           style="-fx-font-size:11px; -fx-font-weight:800; -fx-text-fill:#6d2269;"/>
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Label style="-fx-background-color:#6d2269; -fx-background-radius:6;
                                      -fx-min-width:16; -fx-min-height:16;"/>
                        <Label text="Aujourd'hui" style="-fx-font-size:11px; -fx-text-fill:#475569;"/>
                    </HBox>
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Label style="-fx-background-color:#fef2f2; -fx-border-color:#fca5a5;
                                      -fx-border-width:1; -fx-background-radius:6;
                                      -fx-min-width:16; -fx-min-height:16;"/>
                        <Label text="Jour Ferie" style="-fx-font-size:11px; -fx-text-fill:#475569;"/>
                    </HBox>
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Label style="-fx-background-color:#eff6ff; -fx-border-color:#93c5fd;
                                      -fx-border-width:1; -fx-background-radius:6;
                                      -fx-min-width:16; -fx-min-height:16;"/>
                        <Label text="Conge accepte" style="-fx-font-size:11px; -fx-text-fill:#475569;"/>
                    </HBox>
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Label style="-fx-background-color:#f8f5ff; -fx-border-color:#e0d9f7;
                                      -fx-border-width:1; -fx-background-radius:6;
                                      -fx-min-width:16; -fx-min-height:16;"/>
                        <Label text="Week-end" style="-fx-font-size:11px; -fx-text-fill:#475569;"/>
                    </HBox>
                </HBox>

            </VBox>
        </ScrollPane>
    </VBox>

    <!-- ═══ RIGHT PANEL: Upcoming Holidays ══════════════════════════════ -->
    <VBox spacing="0" prefWidth="320" minWidth="300"
          style="-fx-background-color:#f0ebf9;
                 -fx-border-color:#e0d9f7; -fx-border-width:0 0 0 1.5;">

        <!-- Panel header — same violet -->
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color:#6d2269; -fx-padding:20 22;">
            <Label text="🗓" style="-fx-font-size:20px;"/>
            <VBox spacing="1">
                <Label text="Prochains jours feries"
                       style="-fx-font-size:15px; -fx-font-weight:900; -fx-text-fill:white;"/>
                <Label text="60 prochains jours - Tunisie"
                       style="-fx-font-size:11px; -fx-text-fill:rgba(255,255,255,0.60);"/>
            </VBox>
        </HBox>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background-color:transparent; -fx-background:#f0ebf9;
                           -fx-border-color:transparent;"
                    vbarPolicy="AS_NEEDED" hbarPolicy="NEVER">
            <VBox spacing="14" style="-fx-padding:18;">

                <VBox fx:id="upcomingContainer" spacing="10"/>

                <!-- Info card — white -->
                <VBox spacing="10"
                      style="-fx-background-color:white; -fx-background-radius:18;
                             -fx-border-color:#e0d9f7; -fx-border-width:1.5; -fx-border-radius:18;
                             -fx-padding:16;
                             -fx-effect:dropshadow(gaussian,rgba(109,34,105,0.07),12,0,0,3);">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="ℹ"
                               style="-fx-font-size:13px; -fx-text-fill:white;
                                      -fx-background-color:#6d2269; -fx-background-radius:50;
                                      -fx-min-width:26; -fx-min-height:26; -fx-alignment:center;"/>
                        <Label text="Source de donnees"
                               style="-fx-font-size:13px; -fx-font-weight:800; -fx-text-fill:#3d1a3b;"/>
                    </HBox>
                    <Separator style="-fx-background-color:#f0ebf9;"/>
                    <Label text="API Nager.Date (date.nager.at)"
                           style="-fx-font-size:12px; -fx-font-weight:700; -fx-text-fill:#6d2269;"/>
                    <Label text="Jours feries officiels Tunisie (TN). Fetes islamiques calculees approximativement."
                           wrapText="true"
                           style="-fx-font-size:11px; -fx-text-fill:#64748b;"/>
                    <Label text="Fallback automatique si hors ligne."
                           style="-fx-font-size:11px; -fx-text-fill:#9c5c9a; -fx-font-style:italic;
                                  -fx-background-color:#f0ebf9; -fx-background-radius:10; -fx-padding:5 10;"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </VBox>

</HBox>
