<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="0"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.RhPro.controllers.rh.EventParticipantsController"
      style="-fx-background-color:#f3f0fa;">

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="16"
          style="-fx-background-color:#059669;
                 -fx-padding:20 30;
                 -fx-effect:dropshadow(gaussian,rgba(5,150,105,0.45),18,0,0,6);">
        <Label text="👥" style="-fx-font-size:26px;"/>
        <VBox spacing="2">
            <Label fx:id="titleLabel" text="Participants"
                   style="-fx-font-size:22px; -fx-font-weight:900; -fx-text-fill:white;"/>
            <Label text="Gérez les inscriptions à cet événement"
                   style="-fx-font-size:12px; -fx-text-fill:rgba(255,255,255,0.72);"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="msgLabel"
               style="-fx-font-size:13px; -fx-font-weight:800; -fx-text-fill:white;
                      -fx-background-color:rgba(255,255,255,0.18);
                      -fx-background-radius:20; -fx-padding:6 18;"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color:transparent; -fx-background:#f3f0fa;">
        <VBox spacing="22" style="-fx-padding:26 30;">

            <!-- TABLE CARD -->
            <VBox spacing="16"
                  style="-fx-background-color:white; -fx-background-radius:24;
                         -fx-effect:dropshadow(gaussian,rgba(5,150,105,0.10),22,0,0,6);
                         -fx-padding:28;">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="👥"
                           style="-fx-font-size:15px; -fx-text-fill:white;
                                  -fx-background-color:#059669; -fx-background-radius:50;
                                  -fx-min-width:32; -fx-min-height:32; -fx-alignment:center;"/>
                    <Label text="Liste des participants"
                           style="-fx-font-size:17px; -fx-font-weight:900; -fx-text-fill:#064e3b;"/>
                </HBox>
                <Separator style="-fx-background-color:#d1fae5;"/>

                <TableView fx:id="table" prefHeight="480" VBox.vgrow="ALWAYS"
                           style="-fx-background-color:#f0fdf4; -fx-background-radius:14;
                                  -fx-border-radius:14; -fx-border-color:#a7f3d0; -fx-border-width:1.5;">
                    <columns>
                        <TableColumn fx:id="colId"         text="ID"               prefWidth="90"/>
                        <TableColumn fx:id="colEmployeId"  text="Employé ID"        prefWidth="180"/>
                        <TableColumn fx:id="colDate"       text="Date inscription"  prefWidth="220"/>
                        <TableColumn fx:id="colStatut"     text="Statut"            prefWidth="220"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- ACTION BUTTONS CARD -->
            <HBox spacing="14" alignment="CENTER"
                  style="-fx-background-color:white; -fx-background-radius:24;
                         -fx-effect:dropshadow(gaussian,rgba(5,150,105,0.10),22,0,0,6);
                         -fx-padding:22 28;">

                <Button text="✅  Accepter" onAction="#accept"
                        style="-fx-background-color:#059669; -fx-text-fill:white;
                               -fx-font-weight:900; -fx-font-size:14px;
                               -fx-background-radius:30; -fx-padding:13 28; -fx-cursor:hand;
                               -fx-effect:dropshadow(gaussian,rgba(5,150,105,0.45),14,0,0,4);"/>

                <Button text="❌  Refuser" onAction="#refuse"
                        style="-fx-background-color:#dc2626; -fx-text-fill:white;
                               -fx-font-weight:900; -fx-font-size:14px;
                               -fx-background-radius:30; -fx-padding:13 28; -fx-cursor:hand;
                               -fx-effect:dropshadow(gaussian,rgba(220,38,38,0.45),14,0,0,4);"/>

                <Button text="🔄  Rafraîchir" onAction="#refresh"
                        style="-fx-background-color:#f0ebf9; -fx-text-fill:#6d2269;
                               -fx-font-weight:800; -fx-font-size:13px;
                               -fx-background-radius:30; -fx-border-radius:30;
                               -fx-border-color:#d8b4d6; -fx-border-width:1.5;
                               -fx-padding:12 24; -fx-cursor:hand;"/>
            </HBox>

        </VBox>
    </ScrollPane>
</VBox>
