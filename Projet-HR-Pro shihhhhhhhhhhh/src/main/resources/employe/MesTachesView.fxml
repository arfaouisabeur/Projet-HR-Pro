<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.RhPro.controllers.employe.MesTachesController"
      spacing="20" style="-fx-padding: 20; -fx-background-color: #f3f4f6;">

    <!-- Header with search -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <VBox spacing="5">
            <Label text="Mes tâches"
                   style="-fx-font-size: 28px; -fx-font-weight: 900; -fx-text-fill: #111827;"/>
            <Label text="Tableau Kanban"
                   style="-fx-font-size: 14px; -fx-text-fill: #6b7280;"/>
        </VBox>

        <Region HBox.hgrow="ALWAYS"/>

        <TextField fx:id="searchField" promptText="Rechercher une tâche..."
                   prefWidth="300"
                   style="-fx-background-radius: 25; -fx-border-radius: 25; -fx-border-color: #e5e7eb; -fx-padding: 12 20; -fx-background-color: white;"/>

        <Button text="Rafraîchir" onAction="#refresh"
                style="-fx-background-color: white; -fx-border-color: #e5e7eb; -fx-background-radius: 25; -fx-border-radius: 25; -fx-padding: 12 25; -fx-cursor: hand;"/>
    </HBox>

    <!-- SplitPane with Kanban and Chat -->
    <SplitPane dividerPositions="0.7" VBox.vgrow="ALWAYS">
        <!-- Left side: Kanban Board -->
        <VBox spacing="20">
            <HBox spacing="20" VBox.vgrow="ALWAYS">
                <!-- TODO Column -->
                <VBox fx:id="todoColumn" spacing="10" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #f9fafb; -fx-background-radius: 24; -fx-padding: 20; -fx-border-color: #e5e7eb; -fx-border-radius: 24;"/>

                <!-- DOING Column -->
                <VBox fx:id="doingColumn" spacing="10" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #f9fafb; -fx-background-radius: 24; -fx-padding: 20; -fx-border-color: #e5e7eb; -fx-border-radius: 24;"/>

                <!-- DONE Column -->
                <VBox fx:id="doneColumn" spacing="10" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #f9fafb; -fx-background-radius: 24; -fx-padding: 20; -fx-border-color: #e5e7eb; -fx-border-radius: 24;"/>
            </HBox>
        </VBox>

        <!-- Right side: Chat Panel -->
    <!-- Right side: Chat Panel with its own controller -->
        <fx:include fx:id="chatbot" source="ChatView.fxml" />
    </SplitPane>

    <!-- Bottom status bar -->
    <HBox spacing="10" alignment="CENTER_LEFT"
          style="-fx-background-color: white; -fx-background-radius: 100; -fx-padding: 12 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);">

        <!-- Column counters -->
        <Label fx:id="todoCount" visible="false" managed="false"/>
        <Label fx:id="doingCount" visible="false" managed="false"/>
        <Label fx:id="doneCount" visible="false" managed="false"/>

        <Label text="💡" style="-fx-font-size: 18px;"/>
        <Label text="Cliquez sur les boutons des cartes pour changer le statut"
               style="-fx-text-fill: #6b7280;"/>

        <Region HBox.hgrow="ALWAYS"/>

        <Label fx:id="msgLabel" style="-fx-text-fill: #6b7280;"/>
    </HBox>

</VBox>