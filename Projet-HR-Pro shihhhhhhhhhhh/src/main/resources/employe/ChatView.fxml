<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.RhPro.controllers.employe.ChatbotController"
      spacing="10" style="-fx-background-color: white; -fx-background-radius: 24; -fx-padding: 15;">

    <Label text="🤖 Assistant IA" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
    <Separator/>

    <!-- Chat messages area -->
    <ScrollPane fx:id="chatScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background: transparent; -fx-background-color: transparent;">
        <VBox fx:id="chatMessages" spacing="10" style="-fx-padding: 10;"/>
    </ScrollPane>

    <!-- Input area -->
    <HBox spacing="10">
        <TextField fx:id="chatInput" promptText="Posez une question..." HBox.hgrow="ALWAYS"
                   style="-fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: #e5e7eb; -fx-padding: 10 15;"/>
        <Button fx:id="sendButton" text="Envoyer" onAction="#handleSendButton"
                style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 10 20; -fx-cursor: hand;"/>
    </HBox>
</VBox>