<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="0"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.RhPro.controllers.employe.EventsController"
      style="-fx-background-color:#f3f0fa;">

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="16"
          style="-fx-background-color:#6d2269;
                 -fx-padding:20 30;
                 -fx-effect:dropshadow(gaussian,rgba(109,34,105,0.4),18,0,0,6);">

        <Label text="🎉" style="-fx-font-size:26px;"/>
        <VBox spacing="2">
            <Label text="Evenements"
                   style="-fx-font-size:22px; -fx-font-weight:900; -fx-text-fill:white;"/>
            <Label text="Decouvrez et participez aux evenements HR PRO"
                   style="-fx-font-size:12px; -fx-text-fill:rgba(255,255,255,0.72);"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="msgLabel" text=""
               style="-fx-font-size:12px; -fx-font-weight:700; -fx-text-fill:white;
                      -fx-background-color:rgba(255,255,255,0.18);
                      -fx-background-radius:20; -fx-padding:5 14;"/>
        <Button text="Rafraichir" onAction="#refresh"
                style="-fx-background-color:rgba(255,255,255,0.18); -fx-text-fill:white;
                       -fx-font-weight:800; -fx-font-size:12px;
                       -fx-background-radius:30; -fx-border-color:rgba(255,255,255,0.35);
                       -fx-border-width:1.5; -fx-border-radius:30;
                       -fx-padding:9 20; -fx-cursor:hand;"/>
    </HBox>

    <!-- CONTENT ScrollPane -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color:transparent; -fx-background:#f3f0fa;
                       -fx-border-color:transparent;"
                vbarPolicy="AS_NEEDED" hbarPolicy="NEVER">
        <VBox fx:id="sectionsContainer" spacing="22"
              style="-fx-padding:26 30 30 30; -fx-background-color:#f3f0fa;"/>
    </ScrollPane>

</VBox>
