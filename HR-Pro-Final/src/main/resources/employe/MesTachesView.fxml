<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="mainContainer" spacing="18" style="-fx-padding: 24 26 16 26; -fx-background-color: #f3f0fa;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.RhPro.controllers.employe.MesTachesController">

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="14">
        <VBox spacing="3">
            <Label style="-fx-font-size:26px;-fx-font-weight:900;-fx-text-fill:#1a1a1a;" text="Mes tâches" />
            <Label style="-fx-font-size:13px;-fx-text-fill:#6b7280;" text="Tableau Kanban" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />

        <!-- Chatbot button -->
        <Button fx:id="chatbotBtn" onAction="#openChatbot" prefHeight="38.0" prefWidth="128.0" style="-fx-background-color:#6d2269;-fx-text-fill:white;                        -fx-background-radius:25;-fx-padding:10 20;                        -fx-font-weight:700;-fx-font-size:12px;-fx-cursor:hand;                        -fx-effect:dropshadow(gaussian,rgba(109,34,105,0.35),10,0,0,3);" text="🤖  Assistant IA" />

        <!-- Search -->
        <TextField fx:id="searchField" prefWidth="240" promptText="Rechercher une tâche..." style="-fx-background-radius:25;-fx-border-radius:25;                           -fx-border-color:#ddd6fe;-fx-border-width:1.5;                           -fx-padding:10 18;-fx-background-color:white;                           -fx-font-size:12px;" />

        <!-- Refresh button -->
        <Button onAction="#refresh" style="-fx-background-color:white;-fx-text-fill:#6d2269;                        -fx-background-radius:25;-fx-border-color:#ddd6fe;                        -fx-border-width:1.5;-fx-border-radius:25;                        -fx-padding:10 20;-fx-font-weight:700;                        -fx-font-size:12px;-fx-cursor:hand;" text="Rechercher" />
    </HBox>

    <!-- KANBAN BOARD -->
    <HBox spacing="16" VBox.vgrow="ALWAYS">
        <VBox fx:id="todoColumn" spacing="10" style="-fx-background-color:white;-fx-background-radius:14;                      -fx-padding:16;                      -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),8,0,0,2);" HBox.hgrow="ALWAYS" />
        <VBox fx:id="doingColumn" spacing="10" style="-fx-background-color:white;-fx-background-radius:14;                      -fx-padding:16;                      -fx-effect:dropshadow(gaussian,rgba(109,34,105,0.08),8,0,0,2);" HBox.hgrow="ALWAYS" />
        <VBox fx:id="doneColumn" spacing="10" style="-fx-background-color:white;-fx-background-radius:14;                      -fx-padding:16;                      -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),8,0,0,2);" HBox.hgrow="ALWAYS" />
    </HBox>

    <!-- STATUS BAR -->
    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color:white;-fx-background-radius:100;                  -fx-padding:10 18;                  -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.04),8,0,0,1);">
        <Label fx:id="todoCount" managed="false" visible="false" />
        <Label fx:id="doingCount" managed="false" visible="false" />
        <Label fx:id="doneCount" managed="false" visible="false" />
        <Label style="-fx-font-size:15px;" text="💡" />
        <Label style="-fx-text-fill:#6b7280;-fx-font-size:12px;" text="Cliquez sur les boutons des cartes pour changer le statut" />
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="msgLabel" style="-fx-text-fill:#6b7280;-fx-font-size:12px;-fx-font-weight:600;" />
    </HBox>

    <!-- Chatbot caché (fallback) -->
    <fx:include fx:id="chatbot" managed="false" source="ChatView.fxml" visible="false" />

</VBox>
