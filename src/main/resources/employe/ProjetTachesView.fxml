<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.RhPro.controllers.employe.ProjetTachesController"
      spacing="14" style="-fx-padding:18; -fx-background-color:#f6f6fb;">

    <Label fx:id="titleLabel" text="Tâches du projet"
           style="-fx-font-size:18px; -fx-font-weight:900; -fx-text-fill:#111827;"/>

    <HBox spacing="10">
        <TextField fx:id="titreField" promptText="Titre tâche" prefWidth="240"
                   style="-fx-background-radius:14; -fx-border-radius:14; -fx-border-color:#ececf5; -fx-padding:10 12;"/>

        <TextField fx:id="descField" promptText="Description" prefWidth="320"
                   style="-fx-background-radius:14; -fx-border-radius:14; -fx-border-color:#ececf5; -fx-padding:10 12;"/>

        <ComboBox fx:id="statutCombo" promptText="Statut" prefWidth="160"
                  style="-fx-background-radius:14; -fx-border-radius:14; -fx-border-color:#ececf5; -fx-padding:6 10;"/>

        <TextField fx:id="employeIdField" promptText="Employe ID (assigner)" prefWidth="180"
                   style="-fx-background-radius:14; -fx-border-radius:14; -fx-border-color:#ececf5; -fx-padding:10 12;"/>

        <Button text="➕ Ajouter" onAction="#add"
                style="-fx-background-color:#065f46; -fx-text-fill:white; -fx-background-radius:14; -fx-padding:10 14; -fx-font-weight:900;"/>
    </HBox>

    <TableView fx:id="table" prefHeight="460"
               style="-fx-background-color:white; -fx-background-radius:18; -fx-border-radius:18; -fx-border-color:#ececf5; -fx-padding:8;">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="70"/>
            <TableColumn fx:id="colTitre" text="Titre" prefWidth="240"/>
            <TableColumn fx:id="colStatut" text="Statut" prefWidth="120"/>
            <TableColumn fx:id="colEmploye" text="Assignée à (employe_id)" prefWidth="170"/>
            <TableColumn fx:id="colDesc" text="Description" prefWidth="450"/>
        </columns>
    </TableView>

    <HBox spacing="10">
        <Button text="🔄 Rafraîchir" onAction="#refresh"
                style="-fx-background-color:white; -fx-border-color:#ececf5; -fx-background-radius:14; -fx-border-radius:14; -fx-padding:10 14; -fx-font-weight:900;"/>
        <Button text="🗑 Supprimer sélection" onAction="#deleteSelected"
                style="-fx-background-color:#991b1b; -fx-text-fill:white; -fx-background-radius:14; -fx-padding:10 14; -fx-font-weight:900;"/>
        <Button text="✅ Mettre DONE" onAction="#markDone"
                style="-fx-background-color:#111827; -fx-text-fill:white; -fx-background-radius:14; -fx-padding:10 14; -fx-font-weight:900;"/>
        <Label fx:id="msgLabel" text="" style="-fx-text-fill:#6b7280;"/>
    </HBox>
</VBox>
