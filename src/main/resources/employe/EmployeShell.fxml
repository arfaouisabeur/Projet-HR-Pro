<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<BorderPane prefHeight="820" prefWidth="1400" style="-fx-background-color:#f6f6fb; -fx-font-family:'Segoe UI';" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.RhPro.controllers.employe.EmployeShellController">

    <left>
        <VBox spacing="12" style="-fx-padding: 22; -fx-background-color: linear-gradient(to bottom, #5b2b82, #3b1b57); -fx-pref-width: 300;">
            <Button layoutX="560" layoutY="10" onAction="#goProfil"
                    prefHeight="40" prefWidth="40"
                    style="-fx-background-color:white;
               -fx-background-radius:50;
               -fx-border-color:#e9d8fd;
               -fx-border-radius:50;
               -fx-border-width:2;
               -fx-cursor:hand;
               -fx-effect:dropshadow(gaussian,rgba(91,43,130,0.2),6,0,0,2);"
                    text="👤"/>

            <ImageView fitWidth="150" fitHeight="150" preserveRatio="true">
                <image>
                    <Image url="@/images/logo.png"/>
                </image>
            </ImageView>            <Label fx:id="userLabel" style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size:13px;" text="Employé" />

            <Separator style="-fx-opacity:0.35;" />

            <!-- Money -->
            <Button onAction="#goSalaires" prefHeight="44.0" prefWidth="255.0" style="-fx-background-color: rgba(255,255,255,0.14); -fx-text-fill:white; -fx-background-radius:14; -fx-padding:14; -fx-font-weight:900;" text="💰 Mes salaires" />

            <Button onAction="#goPrimes" prefHeight="44.0" prefWidth="255.0" style="-fx-background-color: rgba(255,255,255,0.08); -fx-text-fill:white; -fx-background-radius:14; -fx-padding:14; -fx-font-weight:900;" text="🎁 Mes primes" />

            <Separator style="-fx-opacity:0.25;" />

            <!-- Requests -->
            <Button onAction="#goConges" prefHeight="44.0" prefWidth="255.0" style="-fx-background-color: rgba(255,255,255,0.10); -fx-text-fill:white; -fx-background-radius:14; -fx-padding:14; -fx-font-weight:900;" text="🗓 Mes congés" />

            <Button onAction="#goServices" prefHeight="44.0" prefWidth="255.0" style="-fx-background-color: rgba(255,255,255,0.10); -fx-text-fill:white; -fx-background-radius:14; -fx-padding:14; -fx-font-weight:900;" text="🛠 Mes services" />

            <Separator style="-fx-opacity:0.25;" />

            <!-- Work -->
            <Button onAction="#goMesProjets" prefHeight="44.0" prefWidth="255.0" style="-fx-background-color: rgba(255,255,255,0.10); -fx-text-fill:white; -fx-background-radius:14; -fx-padding:14; -fx-font-weight:900;" text="📁 Mes projets" />

            <Button onAction="#goMesTaches" prefHeight="44.0" prefWidth="255.0" style="-fx-background-color: rgba(255,255,255,0.10); -fx-text-fill:white; -fx-background-radius:14; -fx-padding:14; -fx-font-weight:900;" text="✅ Mes tâches" />

            <Button onAction="#goEvents" prefHeight="44.0" prefWidth="255.0" style="-fx-background-color: rgba(255,255,255,0.10); -fx-text-fill:white; -fx-background-radius:14; -fx-padding:14; -fx-font-weight:900;" text="📅 Événements" />

            <Button onAction="#goMyParticipations" prefHeight="44.0" prefWidth="255.0" style="-fx-background-color: rgba(255,255,255,0.10); -fx-text-fill:white; -fx-background-radius:14; -fx-padding:14; -fx-font-weight:900;" text="🧍 Mes participations" />

            <Region VBox.vgrow="ALWAYS" />

            <Button onAction="#logout" style="-fx-background-color: rgba(255,255,255,0.10); -fx-text-fill:white; -fx-background-radius:14; -fx-padding:14; -fx-font-weight:900;" text="🚪 Déconnexion" />

        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentPane" style="-fx-padding:22;" />
    </center>
</BorderPane>
