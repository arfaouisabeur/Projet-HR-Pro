<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.RhPro.controllers.rh.EmployeSearchController"
      spacing="12"
      style="-fx-background-color: white;">

    <padding>
        <Insets top="14" right="14" bottom="14" left="14"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <VBox spacing="2">
            <Label text="Recherche employé"
                   style="-fx-font-size: 18px; -fx-font-weight: 900; -fx-text-fill: #111827;"/>
            <Label text="Filtrer puis choisir un employé"
                   style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblCount" text="0"
               style="-fx-text-fill:#6b7280; -fx-font-weight:900; -fx-background-color:#f3f4f6;
                      -fx-background-radius: 999; -fx-padding: 6 10;"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="tfSearch" promptText="Nom / Prénom / Email"
                   style="-fx-background-radius:10; -fx-border-radius:10; -fx-border-color:#e5e7eb; -fx-padding:8 10;"
                   HBox.hgrow="ALWAYS"/>
        <ComboBox fx:id="cbRole" promptText="Rôle" prefWidth="160"/>
        <Button text="✖ Effacer" onAction="#clearFilters"
                style="-fx-background-color: transparent; -fx-border-color:#d1d5db;
                       -fx-background-radius:12; -fx-border-radius:12;
                       -fx-padding:10 14; -fx-font-weight:900; -fx-text-fill:#111827;"/>
    </HBox>

    <TableView fx:id="table" prefHeight="420"
               style="-fx-background-color: transparent; -fx-background-insets: 0;
                      -fx-border-color: #e5e7eb; -fx-border-radius: 14; -fx-background-radius: 14;">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="70"/>
            <TableColumn fx:id="colNom" text="Nom" prefWidth="140"/>
            <TableColumn fx:id="colPrenom" text="Prénom" prefWidth="140"/>
            <TableColumn fx:id="colEmail" text="Email" prefWidth="240"/>
            <TableColumn fx:id="colRole" text="Rôle" prefWidth="120"/>
        </columns>
    </TableView>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Annuler" onAction="#onCancel"
                style="-fx-background-color: transparent; -fx-border-color:#d1d5db;
                       -fx-background-radius:12; -fx-border-radius:12;
                       -fx-padding:10 14; -fx-font-weight:900; -fx-text-fill:#111827;"/>
        <Button text="Choisir" onAction="#onChoose"
                style="-fx-background-color:#6d28d9; -fx-text-fill:white; -fx-background-radius:12;
                       -fx-padding:10 14; -fx-font-weight:900;"/>
    </HBox>

    <Label text="Astuce : double-clic sur une ligne pour choisir"
           style="-fx-text-fill:#9ca3af; -fx-font-size: 11px;"/>

</VBox>