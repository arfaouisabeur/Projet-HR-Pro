<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="540" prefWidth="900"
            style="-fx-font-family:'Segoe UI'; -fx-background-color:#0b0b10;"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.RhPro.controllers.auth.LoginController">

    <center>
        <StackPane style="-fx-padding: 48; -fx-background-color: #5b2b82;">

            <!-- Carte blanche fixe -->
            <VBox maxWidth="420" prefWidth="420"
                  style="-fx-background-color:white;
                         -fx-background-radius:22;
                         -fx-border-radius:22;
                         -fx-border-color:#ececf5;
                         -fx-padding:0;"
                  prefHeight="480">

                <!-- ScrollPane DANS la carte blanche -->
                <ScrollPane fitToWidth="true"
                            hbarPolicy="NEVER"
                            vbarPolicy="AS_NEEDED"
                            style="-fx-background-color:transparent;
                                   -fx-background:transparent;
                                   -fx-background-radius:22;"
                            VBox.vgrow="ALWAYS">

                    <content>
                        <VBox spacing="16"
                              style="-fx-background-color:white;
                                     -fx-padding:28;">

                            <!-- Header -->
                            <VBox spacing="4">
                                <ImageView fitHeight="122" fitWidth="360" preserveRatio="true">
                                    <image>
                                        <Image url="@/images/logo.png"/>
                                    </image>
                                </ImageView>

                                <Region prefHeight="7"/>

                                <Label text="Connexion"
                                       style="-fx-font-size:22px; -fx-font-weight:900; -fx-text-fill:#111827;"/>

                                <Label text="Entre tes identifiants pour continuer."
                                       style="-fx-text-fill:#6b7280; -fx-font-size:13px;"/>
                            </VBox>

                            <Separator style="-fx-opacity:0.35;"/>

                            <!-- Email -->
                            <VBox spacing="2">
                                <Label text="Email"
                                       style="-fx-text-fill:#374151; -fx-font-weight:800;"/>
                                <TextField fx:id="emailField"
                                           promptText="ex: nom.prenom@mail.com"
                                           style="-fx-background-radius:14;
                                                  -fx-border-radius:14;
                                                  -fx-border-color:#ececf5;
                                                  -fx-padding:12 14;
                                                  -fx-font-size:13px;"/>
                                <Label fx:id="emailErrorLabel"
                                       style="-fx-text-fill:#b91c1c; -fx-font-size:12px;"/>
                            </VBox>

                            <!-- Password -->
                            <VBox spacing="6">
                                <Label text="Mot de passe"
                                       style="-fx-text-fill:#374151; -fx-font-weight:800;"/>
                                <PasswordField fx:id="passField"
                                               promptText="••••••••"
                                               style="-fx-background-radius:14;
                                                      -fx-border-radius:14;
                                                      -fx-border-color:#ececf5;
                                                      -fx-padding:12 14;
                                                      -fx-font-size:13px;"/>
                            </VBox>

                            <!-- CAPTCHA -->
                            <Label text="Captcha:"
                                   style="-fx-text-fill:#374151; -fx-font-weight:800;"/>

                            <HBox spacing="10">
                                <VBox>
                                    <ImageView fx:id="imageViewCaptcha"
                                               fitHeight="50" fitWidth="160"/>
                                    <Button text="Rafraichir"
                                            onAction="#refreshCaptcha"
                                            style="-fx-background-color:#5b2b82;
                                                   -fx-text-fill:white;
                                                   -fx-background-radius:14;
                                                   -fx-padding:12 16;
                                                   -fx-font-weight:900;"/>
                                </VBox>
                                <VBox spacing="4">
                                    <TextField fx:id="captchaField"/>
                                    <Label fx:id="captchaError" textFill="red"/>
                                </VBox>
                            </HBox>

                            <!-- Mot de passe oublié -->
                            <Label text="Mot de passe oublie ?"
                                   onMouseClicked="#showForgotPassword"
                                   style="-fx-text-fill:#5b2b82;
                                          -fx-font-weight:bold;
                                          -fx-cursor:hand;
                                          -fx-underline:true;"/>

                            <!-- Forgot Email Box -->
                            <VBox fx:id="forgotPasswordBox"
                                  spacing="8"
                                  visible="false"
                                  managed="false"
                                  style="-fx-background-color:#f5f0ff;
                                         -fx-padding:16;
                                         -fx-background-radius:12;">
                                <Label text="Entre ton email pour recevoir un code :"
                                       style="-fx-font-weight:bold; -fx-text-fill:#374151;"/>
                                <TextField fx:id="forgotEmailField"
                                           promptText="email@exemple.com"
                                           style="-fx-background-radius:10;
                                                  -fx-border-radius:10;
                                                  -fx-border-color:#d8b4fe;
                                                  -fx-padding:10;"/>
                                <Label fx:id="forgotMsg" style="-fx-font-size:12px;"/>
                                <HBox spacing="8">
                                    <Button text="Envoyer le code"
                                            onAction="#sendOtpCode"
                                            style="-fx-background-color:#5b2b82;
                                                   -fx-text-fill:white;
                                                   -fx-background-radius:10;
                                                   -fx-padding:8 16;
                                                   -fx-font-weight:bold;"/>
                                    <Button text="Annuler"
                                            onAction="#cancelForgot"
                                            style="-fx-background-color:#e5e7eb;
                                                   -fx-background-radius:10;
                                                   -fx-padding:8 16;"/>
                                </HBox>
                            </VBox>

                            <!-- OTP Box -->
                            <VBox fx:id="otpBox"
                                  spacing="8"
                                  visible="false"
                                  managed="false"
                                  style="-fx-background-color:#f0fdf4;
                                         -fx-padding:16;
                                         -fx-background-radius:12;">
                                <Label text="Entre le code recu par email :"
                                       style="-fx-font-weight:bold; -fx-text-fill:#374151;"/>
                                <TextField fx:id="otpField"
                                           promptText="000000"
                                           style="-fx-background-radius:10;
                                                  -fx-border-radius:10;
                                                  -fx-border-color:#86efac;
                                                  -fx-padding:10;
                                                  -fx-font-size:20px;
                                                  -fx-font-weight:bold;"/>
                                <Label fx:id="timerLabel"
                                       text="Code valide : 05:00"
                                       style="-fx-text-fill:#5b2b82; -fx-font-weight:bold;"/>
                                <Label fx:id="otpMsg" style="-fx-font-size:12px;"/>
                                <HBox spacing="8">
                                    <Button text="Verifier le code"
                                            onAction="#verifyOtpCode"
                                            style="-fx-background-color:#15803d;
                                                   -fx-text-fill:white;
                                                   -fx-background-radius:10;
                                                   -fx-padding:8 16;
                                                   -fx-font-weight:bold;"/>
                                    <Button text="Annuler"
                                            onAction="#cancelForgot"
                                            style="-fx-background-color:#e5e7eb;
                                                   -fx-background-radius:10;
                                                   -fx-padding:8 16;"/>
                                </HBox>
                            </VBox>

                            <!-- Boutons -->
                            <HBox spacing="10">
                                <Button text="Se connecter"
                                        onAction="#onLogin"
                                        style="-fx-background-color:#5b2b82;
                                               -fx-text-fill:white;
                                               -fx-background-radius:14;
                                               -fx-padding:12 16;
                                               -fx-font-weight:900;"/>
                                <Button text="Retour"
                                        onAction="#back"
                                        style="-fx-background-color:white;
                                               -fx-border-color:#ececf5;
                                               -fx-background-radius:14;
                                               -fx-border-radius:14;
                                               -fx-padding:12 16;
                                               -fx-font-weight:900;"/>
                            </HBox>

                            <Label fx:id="msgLabel"
                                   style="-fx-text-fill:#b91c1c; -fx-font-weight:800;"/>

                        </VBox>
                    </content>
                </ScrollPane>
            </VBox>

        </StackPane>
    </center>

</BorderPane>